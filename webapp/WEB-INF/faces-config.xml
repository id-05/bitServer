<?xml version='1.0' encoding='UTF-8'?>
<faces-config version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/javaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
    http://xmlns.jcp.org/xml/ns/javaee/web-facesconfig_2_2.xsd">


    <navigation-rule>
        <from-view-id>*</from-view-id>

        <navigation-case>
            <from-outcome>autorisePage</from-outcome>
            <to-view-id>/views/autorisePage.xhtml</to-view-id>
        </navigation-case>

        <navigation-case>
            <from-outcome>homePage</from-outcome>
            <to-view-id>/index.xhtml</to-view-id>
        </navigation-case>

        <navigation-case>
            <from-outcome>searchPage</from-outcome>
            <to-view-id>/views/searchPage.xhtml</to-view-id>
        </navigation-case>

        <navigation-case>
            <from-outcome>patientPage</from-outcome>
            <to-view-id>/views/patientinfoPage.xhtml</to-view-id>
        </navigation-case>

        <navigation-case>
            <from-outcome>seriePage</from-outcome>
            <to-view-id>/views/seriePage.xhtml</to-view-id>
        </navigation-case>

        <navigation-case>
            <from-outcome>settingsPage</from-outcome>
            <to-view-id>/views/settingsPage.xhtml</to-view-id>
        </navigation-case>
        
    </navigation-rule>
</faces-config>